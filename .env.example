# This is an example .env file.
# Copy this file to .env and fill in your actual values.
# Lines starting with # are comments.

# Example API Keys (these are typically managed in config.toml but shown for .env format illustration)
# You can override TOML settings with environment variables if the Config class is updated to prioritize them.
# OPENAI_API_KEY="your_openai_api_key_here"
# GOOGLE_API_KEY="your_google_api_key_here"

# Add other environment variables that Devika will use below.
# We will populate this further with variables like GITHUB_DEFAULT_USER_AGENT, etc.

# Example:
# GITHUB_DEFAULT_USER_AGENT="MyDevikaApp/1.0"

# -----------------------------------------------------------------------------
# Service Configurations
# -----------------------------------------------------------------------------

# GitHub Client Configuration
# Defines the base URL for the GitHub API.
# GITHUB_API_BASE_URL="https://api.github.com"
# Default User-Agent header for GitHub API requests.
# GITHUB_DEFAULT_USER_AGENT="DevikaAI/0.1"
# Default timeout in seconds for GitHub API requests.
# GITHUB_DEFAULT_TIMEOUT="10"
# Default number of items per page for paginated GitHub API requests.
# GITHUB_DEFAULT_PER_PAGE="30"

# Git Executable Configuration
# Path to the git executable. Defaults to "git" (assumes it's in PATH).
# GIT_EXECUTABLE_PATH="git"
# Default timeout in seconds for git operations.
# GIT_DEFAULT_TIMEOUT="300"

# Firejail Sandbox Configuration
# Path to the firejail executable. Defaults to "firejail" (assumes it's in PATH).
# FIREJAIL_EXECUTABLE_PATH="firejail"
# Default Firejail profile path. If not set, system defaults or CodeRunner defaults may apply.
# Example: "/etc/firejail/devika.profile"
# FIREJAIL_DEFAULT_PROFILE_PATH=""

# Browser Configuration
# Default User-Agent for browser interactions and web searches.
# BROWSER_DEFAULT_USER_AGENT="Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/91.0.4472.124 Safari/537.36"
